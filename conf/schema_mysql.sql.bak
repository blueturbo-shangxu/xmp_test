-- XMP Auth Server Database Schema
-- Database: xmp_auth_server
-- Description: Schema for Google Ads authorization and data management

-- Create database
CREATE DATABASE IF NOT EXISTS xmp_auth_server
CHARACTER SET utf8mb4
COLLATE utf8mb4_unicode_ci;

USE xmp_auth_server;

-- ========================================
-- Table: accounts
-- Description: Store Google Ads account information
-- ========================================
CREATE TABLE IF NOT EXISTS accounts (
    id BIGINT UNSIGNED AUTO_INCREMENT PRIMARY KEY,
    account_id VARCHAR(50) NOT NULL UNIQUE COMMENT 'Google Ads账户ID',
    customer_id VARCHAR(50) NOT NULL COMMENT 'Google Ads Customer ID (格式: 123-456-7890)',
    account_name VARCHAR(255) NOT NULL COMMENT '账户名称',
    currency_code VARCHAR(10) DEFAULT 'USD' COMMENT '币种',
    timezone VARCHAR(50) DEFAULT 'UTC' COMMENT '时区',
    account_type ENUM('CLIENT', 'MANAGER') DEFAULT 'CLIENT' COMMENT '账户类型',
    status ENUM('ACTIVE', 'INACTIVE', 'SUSPENDED') DEFAULT 'ACTIVE' COMMENT '账户状态',
    manager_customer_id VARCHAR(50) COMMENT 'MCC管理账户ID',
    created_at TIMESTAMP DEFAULT CURRENT_TIMESTAMP,
    updated_at TIMESTAMP DEFAULT CURRENT_TIMESTAMP ON UPDATE CURRENT_TIMESTAMP,
    INDEX idx_customer_id (customer_id),
    INDEX idx_status (status),
    INDEX idx_manager_customer_id (manager_customer_id)
) ENGINE=InnoDB DEFAULT CHARSET=utf8mb4 COLLATE=utf8mb4_unicode_ci COMMENT='Google Ads账户信息表';

-- ========================================
-- Table: oauth_tokens
-- Description: Store OAuth2 tokens for Google Ads API access
-- ========================================
CREATE TABLE IF NOT EXISTS oauth_tokens (
    id BIGINT UNSIGNED AUTO_INCREMENT PRIMARY KEY,
    account_id BIGINT UNSIGNED NOT NULL COMMENT '关联的账户ID',
    access_token TEXT NOT NULL COMMENT '访问令牌(加密存储)',
    refresh_token TEXT NOT NULL COMMENT '刷新令牌(加密存储)',
    token_type VARCHAR(50) DEFAULT 'Bearer' COMMENT 'Token类型',
    expires_at TIMESTAMP NOT NULL COMMENT '访问令牌过期时间',
    scope TEXT COMMENT '授权范围',
    grant_type VARCHAR(50) DEFAULT 'authorization_code' COMMENT '授权类型',
    is_valid BOOLEAN DEFAULT TRUE COMMENT 'Token是否有效',
    last_refreshed_at TIMESTAMP NULL COMMENT '最后刷新时间',
    refresh_count INT DEFAULT 0 COMMENT '刷新次数',
    error_message TEXT COMMENT '最后一次错误信息',
    created_at TIMESTAMP DEFAULT CURRENT_TIMESTAMP,
    updated_at TIMESTAMP DEFAULT CURRENT_TIMESTAMP ON UPDATE CURRENT_TIMESTAMP,
    FOREIGN KEY (account_id) REFERENCES accounts(id) ON DELETE CASCADE,
    INDEX idx_account_id (account_id),
    INDEX idx_expires_at (expires_at),
    INDEX idx_is_valid (is_valid)
) ENGINE=InnoDB DEFAULT CHARSET=utf8mb4 COLLATE=utf8mb4_unicode_ci COMMENT='OAuth令牌表';

-- ========================================
-- Table: authorization_logs
-- Description: Log all authorization attempts and results
-- ========================================
CREATE TABLE IF NOT EXISTS authorization_logs (
    id BIGINT UNSIGNED AUTO_INCREMENT PRIMARY KEY,
    account_id BIGINT UNSIGNED COMMENT '关联的账户ID(如果授权成功)',
    customer_id VARCHAR(50) COMMENT 'Google Ads Customer ID',
    action_type ENUM('AUTHORIZE', 'REFRESH', 'REVOKE', 'VALIDATE') NOT NULL COMMENT '操作类型',
    status ENUM('SUCCESS', 'FAILED', 'PENDING') NOT NULL COMMENT '操作状态',
    error_code VARCHAR(50) COMMENT '错误码',
    error_message TEXT COMMENT '错误详情',
    ip_address VARCHAR(45) COMMENT '请求IP地址',
    user_agent TEXT COMMENT '用户代理',
    request_data JSON COMMENT '请求数据(脱敏)',
    response_data JSON COMMENT '响应数据(脱敏)',
    duration_ms INT COMMENT '操作耗时(毫秒)',
    created_at TIMESTAMP DEFAULT CURRENT_TIMESTAMP,
    FOREIGN KEY (account_id) REFERENCES accounts(id) ON DELETE SET NULL,
    INDEX idx_account_id (account_id),
    INDEX idx_action_type (action_type),
    INDEX idx_status (status),
    INDEX idx_created_at (created_at)
) ENGINE=InnoDB DEFAULT CHARSET=utf8mb4 COLLATE=utf8mb4_unicode_ci COMMENT='授权操作日志表';

-- ========================================
-- Table: campaigns
-- Description: Store Google Ads campaign data
-- ========================================
CREATE TABLE IF NOT EXISTS campaigns (
    id BIGINT UNSIGNED AUTO_INCREMENT PRIMARY KEY,
    account_id BIGINT UNSIGNED NOT NULL COMMENT '关联的账户ID',
    campaign_id VARCHAR(50) NOT NULL COMMENT 'Google Ads Campaign ID',
    campaign_name VARCHAR(255) NOT NULL COMMENT '推广活动名称',
    campaign_status ENUM('ENABLED', 'PAUSED', 'REMOVED') DEFAULT 'ENABLED' COMMENT '状态',
    campaign_type VARCHAR(50) COMMENT '推广活动类型',
    advertising_channel_type VARCHAR(50) COMMENT '广告网络类型',
    budget_amount DECIMAL(15, 2) COMMENT '预算金额',
    budget_period VARCHAR(20) COMMENT '预算周期',
    bidding_strategy_type VARCHAR(50) COMMENT '出价策略类型',
    start_date DATE COMMENT '开始日期',
    end_date DATE COMMENT '结束日期',
    serving_status VARCHAR(50) COMMENT '投放状态',
    raw_data JSON COMMENT '原始数据(JSON)',
    last_synced_at TIMESTAMP NULL COMMENT '最后同步时间',
    created_at TIMESTAMP DEFAULT CURRENT_TIMESTAMP,
    updated_at TIMESTAMP DEFAULT CURRENT_TIMESTAMP ON UPDATE CURRENT_TIMESTAMP,
    FOREIGN KEY (account_id) REFERENCES accounts(id) ON DELETE CASCADE,
    UNIQUE KEY uk_account_campaign (account_id, campaign_id),
    INDEX idx_campaign_status (campaign_status),
    INDEX idx_last_synced_at (last_synced_at)
) ENGINE=InnoDB DEFAULT CHARSET=utf8mb4 COLLATE=utf8mb4_unicode_ci COMMENT='推广活动表';

-- ========================================
-- Table: ad_groups
-- Description: Store Google Ads ad group data
-- ========================================
CREATE TABLE IF NOT EXISTS ad_groups (
    id BIGINT UNSIGNED AUTO_INCREMENT PRIMARY KEY,
    account_id BIGINT UNSIGNED NOT NULL COMMENT '关联的账户ID',
    campaign_id BIGINT UNSIGNED NOT NULL COMMENT '关联的推广活动ID',
    ad_group_id VARCHAR(50) NOT NULL COMMENT 'Google Ads Ad Group ID',
    ad_group_name VARCHAR(255) NOT NULL COMMENT '广告组名称',
    ad_group_status ENUM('ENABLED', 'PAUSED', 'REMOVED') DEFAULT 'ENABLED' COMMENT '状态',
    ad_group_type VARCHAR(50) COMMENT '广告组类型',
    cpc_bid_micros BIGINT COMMENT 'CPC出价(微单位)',
    cpm_bid_micros BIGINT COMMENT 'CPM出价(微单位)',
    target_cpa_micros BIGINT COMMENT '目标CPA(微单位)',
    raw_data JSON COMMENT '原始数据(JSON)',
    last_synced_at TIMESTAMP NULL COMMENT '最后同步时间',
    created_at TIMESTAMP DEFAULT CURRENT_TIMESTAMP,
    updated_at TIMESTAMP DEFAULT CURRENT_TIMESTAMP ON UPDATE CURRENT_TIMESTAMP,
    FOREIGN KEY (account_id) REFERENCES accounts(id) ON DELETE CASCADE,
    FOREIGN KEY (campaign_id) REFERENCES campaigns(id) ON DELETE CASCADE,
    UNIQUE KEY uk_account_ad_group (account_id, ad_group_id),
    INDEX idx_campaign_id (campaign_id),
    INDEX idx_ad_group_status (ad_group_status),
    INDEX idx_last_synced_at (last_synced_at)
) ENGINE=InnoDB DEFAULT CHARSET=utf8mb4 COLLATE=utf8mb4_unicode_ci COMMENT='广告组表';

-- ========================================
-- Table: sync_tasks
-- Description: Track data synchronization tasks
-- ========================================
CREATE TABLE IF NOT EXISTS sync_tasks (
    id BIGINT UNSIGNED AUTO_INCREMENT PRIMARY KEY,
    account_id BIGINT UNSIGNED NOT NULL COMMENT '关联的账户ID',
    task_type ENUM('CAMPAIGNS', 'AD_GROUPS', 'ADS', 'KEYWORDS', 'PERFORMANCE') NOT NULL COMMENT '任务类型',
    status ENUM('PENDING', 'RUNNING', 'COMPLETED', 'FAILED', 'CANCELLED') DEFAULT 'PENDING' COMMENT '任务状态',
    priority INT DEFAULT 5 COMMENT '优先级(1-10, 10最高)',
    start_date DATE COMMENT '数据开始日期',
    end_date DATE COMMENT '数据结束日期',
    total_records INT DEFAULT 0 COMMENT '总记录数',
    processed_records INT DEFAULT 0 COMMENT '已处理记录数',
    failed_records INT DEFAULT 0 COMMENT '失败记录数',
    error_message TEXT COMMENT '错误信息',
    started_at TIMESTAMP NULL COMMENT '开始时间',
    completed_at TIMESTAMP NULL COMMENT '完成时间',
    duration_seconds INT COMMENT '耗时(秒)',
    retry_count INT DEFAULT 0 COMMENT '重试次数',
    next_retry_at TIMESTAMP NULL COMMENT '下次重试时间',
    created_at TIMESTAMP DEFAULT CURRENT_TIMESTAMP,
    updated_at TIMESTAMP DEFAULT CURRENT_TIMESTAMP ON UPDATE CURRENT_TIMESTAMP,
    FOREIGN KEY (account_id) REFERENCES accounts(id) ON DELETE CASCADE,
    INDEX idx_account_id (account_id),
    INDEX idx_task_type (task_type),
    INDEX idx_status (status),
    INDEX idx_priority (priority),
    INDEX idx_next_retry_at (next_retry_at),
    INDEX idx_created_at (created_at)
) ENGINE=InnoDB DEFAULT CHARSET=utf8mb4 COLLATE=utf8mb4_unicode_ci COMMENT='同步任务表';

-- ========================================
-- Table: api_rate_limits
-- Description: Track API rate limit usage
-- ========================================
CREATE TABLE IF NOT EXISTS api_rate_limits (
    id BIGINT UNSIGNED AUTO_INCREMENT PRIMARY KEY,
    account_id BIGINT UNSIGNED NOT NULL COMMENT '关联的账户ID',
    endpoint VARCHAR(255) NOT NULL COMMENT 'API端点',
    request_count INT DEFAULT 0 COMMENT '请求次数',
    quota_limit INT COMMENT '配额限制',
    quota_remaining INT COMMENT '剩余配额',
    window_start TIMESTAMP NOT NULL COMMENT '时间窗口开始',
    window_end TIMESTAMP NOT NULL COMMENT '时间窗口结束',
    is_throttled BOOLEAN DEFAULT FALSE COMMENT '是否被限流',
    created_at TIMESTAMP DEFAULT CURRENT_TIMESTAMP,
    updated_at TIMESTAMP DEFAULT CURRENT_TIMESTAMP ON UPDATE CURRENT_TIMESTAMP,
    FOREIGN KEY (account_id) REFERENCES accounts(id) ON DELETE CASCADE,
    INDEX idx_account_id (account_id),
    INDEX idx_window_end (window_end),
    INDEX idx_is_throttled (is_throttled)
) ENGINE=InnoDB DEFAULT CHARSET=utf8mb4 COLLATE=utf8mb4_unicode_ci COMMENT='API速率限制表';
