# Python环境配置文件
# XMP Auth Server - Google Ads Authorization System

# 服务器配置
ENV=development
HOST=0.0.0.0
PORT=8000
DEBUG=True

# 数据库配置 (PostgreSQL)
DB_HOST=db.office.pg.domob-inc.cn
DB_PORT=5433
DB_USER=socialbooster
DB_PASSWORD=B<JRsi3.lI
DB_NAME=socialbooster
DB_POOL_SIZE=10
DB_MAX_OVERFLOW=20

# Google OAuth2 配置
GOOGLE_CLIENT_ID=your_google_client_id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=your_google_client_secret
GOOGLE_REDIRECT_URI=http://localhost:8000/auth/callback
GOOGLE_AUTH_SCOPES=https://www.googleapis.com/auth/adwords

# Google Ads API 配置
GOOGLE_ADS_DEVELOPER_TOKEN=your_developer_token
GOOGLE_ADS_API_VERSION=v16
GOOGLE_ADS_LOGIN_CUSTOMER_ID=

# Session配置
SESSION_SECRET=your_session_secret_key_here
SESSION_COOKIE_NAME=xmp_session
SESSION_MAX_AGE=86400

# JWT配置
JWT_SECRET=your_jwt_secret_key_at_least_32_characters_long
JWT_TOKEN_EXPIRE_DAYS=180

# 飞书配置
FEISHU_APP_ID=your_feishu_app_id
FEISHU_APP_SECRET=your_feishu_app_secret
FEISHU_TOMATO_APP_ID=your_tomato_app_id
FEISHU_TOMATO_APP_SECRET=your_tomato_app_secret
FEISHU_TOKEN_URL=https://passport.feishu.cn/suite/passport/oauth/token
FEISHU_USER_URL=https://passport.feishu.cn/suite/passport/oauth/userinfo

# 日志配置
LOG_LEVEL=INFO
LOG_FORMAT=%(asctime)s - %(name)s - %(levelname)s - %(message)s
LOG_FILE=logs/app.log
LOG_MAX_BYTES=10485760
LOG_BACKUP_COUNT=5

# 同步任务配置
SYNC_INTERVAL_MINUTES=60
SYNC_BATCH_SIZE=1000
MAX_RETRY_COUNT=3
RETRY_DELAY_SECONDS=60

# Redis配置
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=
REDIS_DB=0

# 任务队列配置
TASK_QUEUE_NAME=sync_task_queue
TASK_RUNNING_SET=sync_task_running
TASK_LOCK_PREFIX=sync_task_lock:
TASK_EXEC_LOCK_PREFIX=sync_task_exec_lock:
TASK_LOCK_TIMEOUT=30
TASK_LOCK_RENEW_INTERVAL=10

# API速率限制配置
RATE_LIMIT_REQUESTS=100
RATE_LIMIT_WINDOW_SECONDS=60

# CORS配置
CORS_ORIGINS=http://localhost:8000,http://localhost:3000
CORS_ALLOW_CREDENTIALS=True

# 安全配置
ALLOWED_HOSTS=localhost,127.0.0.1
SECURE_COOKIES=False
